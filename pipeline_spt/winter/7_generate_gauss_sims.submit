#!/bin/bash
#SBATCH -t 6:00:00
#SBATCH --partition=SPT3G
#SBATCH --account=SPT3G
#SBATCH --exclusive
#SBATCH --array=0-30%16
#SBATCH --job-name=m_gauss

source deactivate 
source /lcrc/project/SPT3G/users/ac.yomori/setups/setup_analysis.sh

yaml=spt3g.yaml

python src/generate_gauss_sims.py ${yaml} cmbmv 1 $SLURM_ARRAY_TASK_ID
python src/generate_gauss_sims.py ${yaml} cmbynull 1 $SLURM_ARRAY_TASK_ID
